  "autoupdate": true,
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "/opt/homebrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "type": "local"
    },
    "metronous": {
      "command": [
        "/Users/maxidelfino/.local/bin/metronous",
        "mcp"
      ],
      "type": "local"
    },
    "tradingview": {
      "command": [
        "node",
        "./tradingview-mcp/src/server.js"
      ],
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "plugin": [
    "opencode-anthropic-login-via-cli@latest"
  ]
}

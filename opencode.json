{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "QuantOrchestrator": {
      "description": "Pure orchestrator for algorithmic trading and trading-bot design",
      "mode": "primary",
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "engram_mem_context": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_save_prompt": true,
        "engram_mem_search": true,
        "engram_mem_session_summary": true,
        "glob": true,
        "grep": true,
        "read": true,
        "task": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "strategy-architect": "allow",
          "backtesting-engineer": "allow",
          "execution-engineer": "allow",
          "risk-engineer": "allow",
          "market-structure-researcher": "allow",
          "prediction-market-quant": "allow"
        }
      }
    },
    "PromptEngineer": {
      "description": "Production-grade prompt engineer that turns vague requests into copy-paste-ready prompts for OpenCode and LLM workflows",
      "mode": "primary",
      "prompt": "{file:./prompts/prompt-engineer.md}",
      "tools": {
        "delegate": true,
        "delegation_list": true,
        "delegation_read": true,
        "engram_mem_context": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_save_prompt": true,
        "engram_mem_search": true,
        "engram_mem_session_summary": true,
        "glob": true,
        "grep": true,
        "read": true,
        "skill": true,
        "task": true
      }
    },
    "strategy-architect": {
      "description": "Designs strategies, edges and hypothesis-driven trading systems",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/strategy-architect.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "read": true,
        "task": true,
        "tradingview_*": true,
        "write": true
      }
    },
    "backtesting-engineer": {
      "description": "Builds and evaluates historical backtests for trading strategies",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/backtesting-engineer.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "read": true,
        "task": true,
        "tradingview_*": true,
        "write": true
      }
    },
    "execution-engineer": {
      "description": "Designs execution engines, venue adapters and order lifecycle logic",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/execution-engineer.md}",
      "tools": {
        "bash": true,
        "delegate": true,
        "edit": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "read": true,
        "task": true,
        "write": true
      }
    },
    "risk-engineer": {
      "description": "Defines risk rules, position sizing and capital protection controls",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/risk-engineer.md}",
      "tools": {
        "bash": true,
        "engram_mem_get_observation": true,
        "engram_mem_save": true,
        "engram_mem_search": true,
        "read": true,
        "task": true,
        "tradingview_*": true,
        "write": true
      }
    },
    "market-structure-researcher": {
      "description": "Researches DEX microstructure, arbitrage, MEV and sniping constraints",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/market-structure-researcher.md}",
      "tools": {
        "bash": true,
        "chrome-devtools_*": true,
        "context7_*": true,
        "engram_mem_save": true,
        "read": true,
        "tradingview_*": true,
        "webfetch": true,
        "write": true
      }
    },
    "prediction-market-quant": {
      "description": "Designs and evaluates strategies for prediction markets",
      "hidden": false,
      "mode": "subagent",
      "prompt": "{file:./prompts/prediction-market-quant.md}",
      "tools": {
        "bash": true,
        "context7_*": true,
        "engram_mem_save": true,
        "read": true,
        "task": true,
        "webfetch": true,
        "write": true
      }
    }
  },
  "autoupdate": true,
  "mcp": {
    "tradingview": {
      "command": [
        "node",
        "./tradingview-mcp/src/server.js"
      ],
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "plugin": [
    "opencode-anthropic-login-via-cli@latest"
  ]
}
